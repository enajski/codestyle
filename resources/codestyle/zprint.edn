;; Bundled default zprint config for codestyle's :advanced-format.
;;
;; Adopted from the vis project's battle-tested `.zprint.edn`. It keeps the
;; previous visual rules, but tightens the custom :option-fn guides around
;; cases zprint can reach while recursively formatting nested lists:
;;
;;   1. `:option-fn` guides can be re-invoked on nested lists when a fallback
;;      returns only `{:guide [:element-*]}`. Anonymous-fn literals `#(...)`
;;      expand to `(fn* ...)`, so the `fn*` guard in cond->/cond->> is reached
;;      during recursive descent, not while formatting the outer threading form.
;;      It hands that inner list back to zprint's default formatter and disables
;;      further recursive :option-fn calls.
;;   2. The cond->/cond->> guides now distinguish normal forms with an init slot
;;      (even `len`) from recursively-descended, no-init list shapes (odd `len`).
;;      The old `(quot (- len 2) 2)` only counted the init-slot shape correctly.
;;
;; Same visual rules as before (see README) — only the edge-case handling and
;; the fn-map coverage (when-let/when-some/if-let/if-some) are stronger.

{:width 100

 ;; Binding forms (let, loop, binding, with-open, etc.):
 ;; each value on its own line, blank line between pairs for visual separation.
 ;; Single-pair exception: k and v on one line, no blank line before body.
 :binding {:flow?         true
           :indent        0
           :nl-separator? true}

 ;; Comments: preserve lines exactly as written, no merging or reflowing
 :comment {:wrap?       false
           :smart-wrap? false}

 ;; Map literals: one key-value per line when multi-entry maps don't fit on one line, no commas
 :map {:indent 0
       :comma? false}

 ;; Pair forms (cond, assoc, etc.): keep values aligned, no blank separators
 :pair {:indent 0}

 ;; cond->/cond->>/case: each test on its own line, value on next line,
 ;; blank line between clauses for visual separation.
 ;;
 ;; let/loop/for/doseq/etc.: binding vector flows (name on one line, value on next,
 ;; blank line between pairs), then blank line before body forms.
 ;; Single-pair exception: [k v] on one line, single newline before body.
 ;;
 ;; fn: for single-arity forms, put the signature vector on its own line before the body.
 ;;
 ;; Requires {:search-config? true} when invoking zprint.main (see bin/format).
 :fn-map
 {"map" :hang
  "mapv" :hang
  "mapcat" :hang
  "filter" :hang
  "reduce" :hang

  ;; The fn* branch below is for recursively-reached anonymous-fn literals,
  ;; not for the outer cond->/cond->> form (whose first element is cond-> or
  ;; cond->>). When the no-pair fallback is used, zprint may keep invoking this
  ;; same option-fn on inner lists unless we stop at fn* and disable further
  ;; list option-fn recursion.
  "cond->"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (if (= 'fn* (first sexpr))
                    {:guide [:element-*] :next-inner {:list {:option-fn nil}}}
                    (let [has-init?  (even? len)
                          pair-count (quot (if has-init? (- len 2) (- len 1)) 2)
                          head       (if has-init? [:element :element :newline] [:element :newline])]
                      (if (pos? pair-count)
                        {:guide (into head
                                  (mapcat (fn [i]
                                            (if (< i (dec pair-count))
                                              [:element :newline :element :newline :newline]
                                              [:element :newline :element]))
                                    (range pair-count)))
                         :next-inner {:list {:option-fn nil}}}
                        {:guide [:element-*]}))))}}]

  "cond->>"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (if (= 'fn* (first sexpr))
                    {:guide [:element-*] :next-inner {:list {:option-fn nil}}}
                    (let [has-init?  (even? len)
                          pair-count (quot (if has-init? (- len 2) (- len 1)) 2)
                          head       (if has-init? [:element :element :newline] [:element :newline])]
                      (if (pos? pair-count)
                        {:guide (into head
                                  (mapcat (fn [i]
                                            (if (< i (dec pair-count))
                                              [:element :newline :element :newline :newline]
                                              [:element :newline :element]))
                                    (range pair-count)))
                         :next-inner {:list {:option-fn nil}}}
                        {:guide [:element-*]}))))}}]

  "case"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (if (= 'fn* (first sexpr))
                    {:guide [:element-*] :next-inner {:list {:option-fn nil}}}
                    (let [rest-count   (- len 2)
                          has-default? (odd? rest-count)
                          pair-count   (quot rest-count 2)
                          pairs-guide  (mapcat (fn [i]
                                                 (if (< i (dec pair-count))
                                                   [:element :newline :element :newline :newline]
                                                   [:element :newline :element]))
                                         (range pair-count))
                          default-guide (when has-default? [:newline :newline :element])
                          guide (into [:element :element :newline]
                                  (concat pairs-guide default-guide))]
                      {:guide guide :next-inner {:list {:option-fn nil}}})))}}]

  ;; Binding forms: :element-binding-vec formats the [bindings] vector using the
  ;; :binding config, then :newline :newline inserts a blank line before the body.
  ;; Single-pair exception: override :binding to not flow, use single :newline.
  "fn"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (let [named?      (symbol? (second sexpr))
                        vector-idx  (if named? 2 1)
                        signature   (nth sexpr vector-idx nil)
                        body-count  (- len (inc vector-idx))
                        guide-head  (if named?
                                      [:element :element :element :newline]
                                      [:element :element :newline])]
                    (if (vector? signature)
                      {:guide (into guide-head
                                (when (pos? body-count)
                                  (into [:element-best]
                                    (mapcat (fn [_] [:newline :element-best])
                                      (range (dec body-count))))))
                       :next-inner {:list {:option-fn nil}}}
                      {:guide [:element-*]})))}}]

  "let"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (let [pair-count   (quot (count (second sexpr)) 2)
                        single-pair? (= pair-count 1)
                        body-count   (- len 2)
                        newlines     (if single-pair? [:newline] [:newline :newline])
                        guide        (into (into [:element :element-binding-vec] newlines)
                                       (when (pos? body-count)
                                         (into [:element-best]
                                           (mapcat (fn [_] [:newline :element-best])
                                             (range (dec body-count))))))]
                    (cond-> {:guide guide :next-inner {:list {:option-fn nil}}}
                      single-pair? (merge {:binding {:flow?         false
                                                     :nl-separator? false}}))))}}]

  "loop"
  [:guided
   {:list
    {:option-fn (fn [options len sexpr]
                  (let [pair-count   (quot (count (second sexpr)) 2)
                        single-pair? (= pair-count 1)
